<UserControl x:Class="DeviceServiceManager.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 1. MODERN TEXTBOX STYLE -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Wenn der Nutzer ins Feld klickt: Blauer Rahmen, weißer Hintergrund -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#A5B1C2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 2. MODERN BUTTON STYLE (Blau) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Eigener Hover-Effekt (dunkleres Blau) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 3. CANCEL BUTTON STYLE (Grau) -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7F8C8D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 4. SLIDE-IN & SLIDE-OUT ANIMATION FÜR DAS FORMULAR -->
        <Style x:Key="AnimatedFormStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="50"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFormVisible}" Value="True">

                    <!-- REIN-GLEITEN (Enter) -->
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <!-- Formular SOFORT sichtbar machen, damit die Animation starten kann -->
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>

                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="50" To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>

                    <!-- RAUS-GLEITEN (Exit) -->
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <!-- Sanft ausblenden und nach rechts schieben -->
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="50" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <!-- ERST NACH 0.2 SEKUNDEN (wenn die Animation fertig ist) aus dem Layout entfernen! -->
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>

                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="20"/>
            <!-- Etwas mehr Abstand -->
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <!-- LINKE SEITE: KUNDENLISTE -->
        <Border Background="White" CornerRadius="8" Padding="15">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" Direction="320" ShadowDepth="2" BlurRadius="5" Opacity="0.4"/>
            </Border.Effect>

            <!-- DataTrigger für die automatische Breite -->
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Grid.Column" Value="0" />
                    <Setter Property="Grid.ColumnSpan" Value="1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFormVisible}" Value="False">
                            <!-- Weiche Animation der Breite ist nativ in WPF sehr komplex, daher belassen wir es beim harten Umschalten des Spans, 
                                 aber das Formular rechts animiert sich weich! -->
                            <Setter Property="Grid.ColumnSpan" Value="3" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Kundenübersicht" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <Grid>
                        <!-- TextBox nutzt nun automatisch unseren neuen Style -->
                        <TextBox Padding="10,8,30,8" Margin="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="#F8F9FA"/>
                        <Image Source="/Assets/search_icon.png" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" Opacity="0.5"/>
                    </Grid>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Customers}" 
                          SelectedItem="{Binding SelectedCustomer}"
                          AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                          BorderThickness="1" BorderBrush="#E0E0E0" Background="White" RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kd-Nr." Binding="{Binding CustomerNumber}" Width="Auto"/>
                        <DataGridTextColumn Header="Firmenname" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="Ansprechpartner" Binding="{Binding ContactPerson}" Width="1*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- FIX: HorizontalAlignment="Left" verhindert das unschöne Strecken! -->
                <Button Grid.Row="2" Content="+ Neuer Kunde" Command="{Binding CreateNewCustomerCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Width="150" Margin="0,15,0,0"/>
            </Grid>
        </Border>

        <!-- RECHTE SEITE: KUNDENDETAILS (Nutzt nun den AnimatedFormStyle!) -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="25" Style="{StaticResource AnimatedFormStyle}">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" Direction="320" ShadowDepth="2" BlurRadius="5" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Kundendetails" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel DataContext="{Binding SelectedCustomer}">

                        <TextBlock Text="STAMMDATEN" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>

                        <StackPanel>
                            <TextBlock Text="Firmenname *" Foreground="#34495E" FontSize="13"/>
                            <TextBox Text="{Binding Name}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ansprechpartner" Foreground="#34495E" FontSize="13"/>
                                <TextBox Text="{Binding ContactPerson}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="E-Mail Adresse" Foreground="#34495E" FontSize="13"/>
                                <TextBox Text="{Binding Email}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Telefonnummer" Foreground="#34495E" FontSize="13"/>
                            <TextBox Text="{Binding Phone}" Width="200" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <Separator Margin="0,5,0,20" Background="#EEEEEE"/>

                        <TextBlock Text="RECHNUNGSADRESSE" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>
                        <StackPanel DataContext="{Binding BillingAddress}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Straße *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding Street}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hausnr. *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding HouseNumber}"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PLZ *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding ZipCode}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Ort *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding City}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Land *" Foreground="#34495E" FontSize="13"/>
                                    <ComboBox ItemsSource="{Binding DataContext.AvailableCountries, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                              SelectedItem="{Binding Country}" Margin="0,5,0,15" Padding="5"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Separator Margin="0,5,0,20" Background="#EEEEEE"/>

                        <CheckBox Content="Abweichende Lieferadresse angeben" 
                                  IsChecked="{Binding DataContext.IsDeliveryAddressDifferent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  Margin="0,0,0,20" FontSize="13" FontWeight="SemiBold" Foreground="#3498DB" Cursor="Hand"/>

                        <!-- Lieferadresse -->
                        <StackPanel DataContext="{Binding DeliveryAddress}" 
                                    Visibility="{Binding DataContext.IsDeliveryAddressDifferent, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="LIEFERADRESSE" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Straße *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding Street}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hausnr. *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding HouseNumber}"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PLZ *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding ZipCode}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Ort *" Foreground="#34495E" FontSize="13"/>
                                    <TextBox Text="{Binding City}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Land *" Foreground="#34495E" FontSize="13"/>
                                    <ComboBox ItemsSource="{Binding DataContext.AvailableCountries, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                              SelectedItem="{Binding Country}" Margin="0,5,0,15" Padding="5"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Buttonbereich -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Abbrechen" Command="{Binding CancelCommand}" 
                            Style="{StaticResource CancelButtonStyle}" Margin="0,0,10,0" Width="100"/>

                    <Button Content="Speichern" Command="{Binding SaveCustomerCommand}" 
                            Style="{StaticResource PrimaryButtonStyle}" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>