<UserControl x:Class="DeviceServiceManager.Views.ContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <!-- Wir nutzen exakt dieselben Ressourcen wie in der CustomerView -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- TEXTBOX & COMBOBOX STYLE -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7F8C8D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SLIDE-IN ANIMATION -->
        <Style x:Key="AnimatedFormStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="50"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFormVisible}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="50" To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="50" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- HAUPT-LAYOUT -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <!-- LINKE SEITE: VERTRAGSLISTE -->
        <Border Background="White" CornerRadius="8" Padding="15">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" Direction="320" ShadowDepth="2" BlurRadius="5" Opacity="0.4"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFormVisible}" Value="False">
                            <Setter Property="Grid.ColumnSpan" Value="3"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Wartungsverträge" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <Grid>
                        <TextBox Padding="10,8,30,8" Margin="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="#F8F9FA"/>
                        <Image Source="/Assets/search_icon.png" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" Opacity="0.5"/>
                    </Grid>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Contracts}" SelectedItem="{Binding SelectedContract}"
                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" 
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                          BorderThickness="1" BorderBrush="#E0E0E0" Background="White" RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vertragsnummer" Binding="{Binding ContractNumber}" Width="Auto"/>
                        <DataGridTextColumn Header="Kunde" Binding="{Binding Customer.Name}" Width="2*"/>
                        <DataGridTextColumn Header="Enddatum" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="1*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2" Content="+ Neuer Vertrag" Command="{Binding CreateNewContractCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Width="150" Margin="0,15,0,0"/>
            </Grid>
        </Border>

        <!-- RECHTE SEITE: VERTRAGSDETAILS -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="25" Style="{StaticResource AnimatedFormStyle}">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" Direction="320" ShadowDepth="2" BlurRadius="5" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Vertragsdetails bearbeiten" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel DataContext="{Binding SelectedContract}">

                        <!-- VERTRAGSKOPF -->
                        <TextBlock Text="KOPFDATEN" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Vertragsnummer *" Foreground="#34495E" FontSize="13"/>
                                <TextBox Text="{Binding ContractNumber}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Kunde (Zuweisung) *" Foreground="#34495E" FontSize="13"/>

                                <!-- DIE MAGISCHE SUCHBARE COMBOBOX -->
                                <ComboBox IsEditable="True" IsTextSearchEnabled="True" 
                                          ItemsSource="{Binding DataContext.AvailableCustomers, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                          DisplayMemberPath="Name" 
                                          SelectedValuePath="Id" 
                                          SelectedValue="{Binding CustomerId}" 
                                          Margin="0,5,0,15" Padding="5"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Startdatum *" Foreground="#34495E" FontSize="13"/>
                                <!-- DatePicker für saubere Datumsauswahl -->
                                <DatePicker SelectedDate="{Binding StartDate}" Margin="0,5,0,15" Padding="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Enddatum *" Foreground="#34495E" FontSize="13"/>
                                <DatePicker SelectedDate="{Binding EndDate}" Margin="0,5,0,15" Padding="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Status" Foreground="#34495E" FontSize="13"/>
                                <!-- Einfaches Dropdown für Status -->
                                <ComboBox SelectedValue="{Binding Status}" SelectedValuePath="Content" Margin="0,5,0,15" Padding="5">
                                    <ComboBoxItem Content="aktiv"/>
                                    <ComboBoxItem Content="abgelaufen"/>
                                    <ComboBoxItem Content="gekündigt"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Bemerkung" Foreground="#34495E" FontSize="13"/>
                            <TextBox Text="{Binding Remarks}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>

                        <Separator Margin="0,10,0,20" Background="#EEEEEE"/>

                        <!-- GERÄTE MANAGEMENT (Hier kommen im nächsten Schritt die Geräte rein!) -->
                        <TextBlock Text="ABGEDECKTE GERÄTE (Demnächst...)" FontSize="12" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>

                        <DataGrid ItemsSource="{Binding CoveredDevices}" AutoGenerateColumns="False" IsReadOnly="True" 
                                  HeadersVisibility="Column" Background="#FAFAFA" BorderBrush="#E0E0E0" Height="150" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Seriennummer" Binding="{Binding SerialNumber}" Width="*"/>
                                <DataGridTextColumn Header="Hersteller" Binding="{Binding Manufacturer}" Width="Auto"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="+ Gerät zum Vertrag hinzufügen" Background="White" Foreground="#3498DB" BorderBrush="#3498DB" BorderThickness="1" 
                                Cursor="Hand" Padding="10,5" HorizontalAlignment="Left" FontWeight="SemiBold"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Buttonbereich -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Abbrechen" Command="{Binding CancelCommand}" Style="{StaticResource CancelButtonStyle}" Margin="0,0,10,0" Width="100"/>
                    <Button Content="Speichern" Command="{Binding SaveContractCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>