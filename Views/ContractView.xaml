<UserControl x:Class="DeviceServiceManager.Views.ContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <!-- Wir nutzen exakt dieselben Ressourcen wie in der CustomerView -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- TEXTBOX & COMBOBOX STYLE -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- STYLE FÜR DATEPICKER -->
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7F8C8D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SLIDE-IN ANIMATION -->
        <Style x:Key="AnimatedFormStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="50"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFormVisible}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="50" To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="50" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- HAUPT-LAYOUT -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <!-- LINKE SEITE: VERTRAGSLISTE -->
        <Border Background="White" CornerRadius="8" Padding="15">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" Direction="320" ShadowDepth="2" BlurRadius="5" Opacity="0.4"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFormVisible}" Value="False">
                            <Setter Property="Grid.ColumnSpan" Value="3"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Wartungsverträge" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <Grid>
                        <TextBox Padding="10,8,30,8" Margin="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="#F8F9FA"/>
                        <Image Source="/Assets/search_icon.png" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" Opacity="0.5"/>
                    </Grid>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Contracts}" SelectedItem="{Binding SelectedContract}"
                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" 
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                          BorderThickness="1" BorderBrush="#E0E0E0" Background="White" RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vertragsnummer" Binding="{Binding ContractNumber}" Width="Auto"/>
                        <DataGridTextColumn Header="Kunde" Binding="{Binding Customer.Name}" Width="2*"/>
                        <DataGridTextColumn Header="Enddatum" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="1*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2" Content="+ Neuer Vertrag" Command="{Binding CreateNewContractCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Width="150" Margin="0,15,0,0"/>
            </Grid>
        </Border>

        <!-- RECHTE SEITE: VERTRAGSDETAILS -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="25" Style="{StaticResource AnimatedFormStyle}">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" Direction="320" ShadowDepth="2" BlurRadius="5" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Vertragsdetails bearbeiten" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel DataContext="{Binding EditableContract}">

                        <!-- VERTRAGSKOPF -->
                        <TextBlock Text="KOPFDATEN" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Kunde (Zuweisung) *" Foreground="#34495E" FontSize="13"/>
                                <ComboBox IsEditable="True" IsTextSearchEnabled="True" 
                                          ItemsSource="{Binding DataContext.AvailableCustomers, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                          DisplayMemberPath="Name" 
                                          SelectedValuePath="Id" 
                                          SelectedValue="{Binding CustomerId, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Status" Foreground="#34495E" FontSize="13"/>
                                <ComboBox SelectedValue="{Binding Status}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="aktiv"/>
                                    <ComboBoxItem Content="abgelaufen"/>
                                    <ComboBoxItem Content="gekündigt"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Startdatum *" Foreground="#34495E" FontSize="13"/>
                                <DatePicker SelectedDate="{Binding StartDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Enddatum *" Foreground="#34495E" FontSize="13"/>
                                <DatePicker SelectedDate="{Binding EndDate}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Bemerkung" Foreground="#34495E" FontSize="13"/>
                            <TextBox Text="{Binding Remarks}" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>
                        </StackPanel>

                        <Separator Margin="0,10,0,20" Background="#EEEEEE"/>

                        <!-- GERÄTE MANAGEMENT -->
                        <Grid Margin="0,0,0,10">
                            <!-- Titel links -->
                            <TextBlock Text="ABGEDECKTE GERÄTE" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" VerticalAlignment="Center"/>

                            <!-- Suchfeld für Geräte (rechtsbündig) -->
                            <Grid Width="200" HorizontalAlignment="Right">
                                <TextBox Padding="5,4,25,4" Margin="0" Text="{Binding DataContext.DeviceSearchText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" Background="#FAFAFA" FontSize="12"/>
                                <Image Source="/Assets/search_icon.png" Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" IsHitTestVisible="False" Opacity="0.4"/>
                            </Grid>
                        </Grid>

                        <DataGrid ItemsSource="{Binding DataContext.DevicesView, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                  AutoGenerateColumns="False" IsReadOnly="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="False" 
                                  HeadersVisibility="Column" Background="#FAFAFA" BorderBrush="#E0E0E0" Height="220" Margin="0,0,0,10">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="inaktiv">
                                            <Setter Property="Background" Value="#FFF5F5"/>
                                            <Setter Property="Foreground" Value="#C0392B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="inaktiv">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                            <Setter Property="Foreground" Value="#95A5A6"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F2F6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <!-- Die Texte teilen sich den restlichen Platz fair auf (*) -->
                                <DataGridTextColumn Header="Seriennummer *" Binding="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                                <DataGridTextColumn Header="Hersteller *" Binding="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="Typ" Binding="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>

                                <DataGridTemplateColumn Header="Status" Width="100" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#7F8C8D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="aktiv">
                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- DEFEKT-BUTTON -->
                                <DataGridTemplateColumn Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Gerät deaktivieren" 
                                                    Command="{Binding DataContext.DeactivateDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Background="Transparent" Foreground="#E74C3C" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" Margin="10,0,10,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="inaktiv">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Der Papierkorb bekommt feste 45 Pixel -->
                                <DataGridTemplateColumn Width="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    ToolTip="Gerät aus Vertrag entfernen"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand">

                                                <Image Source="/Assets/delete_icon.png" Width="16" Height="16" Opacity="0.6"/>

                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="+ Neues Gerät eintragen" 
                                Command="{Binding DataContext.AddDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                Background="White" Foreground="#3498DB" BorderBrush="#3498DB" BorderThickness="1" 
                                Cursor="Hand" Padding="10,5" HorizontalAlignment="Left" FontWeight="SemiBold"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Buttonbereich -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Abbrechen" Command="{Binding CancelCommand}" Style="{StaticResource CancelButtonStyle}" Margin="0,0,10,0" Width="100"/>
                    <Button Content="Speichern" Command="{Binding SaveContractCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>