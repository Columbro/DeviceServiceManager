<Window x:Class="DeviceServiceManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:DeviceServiceManager.ViewModels"
        xmlns:local="clr-namespace:DeviceServiceManager.Views"
        mc:Ignorable="d"
        Title="Device Service Manager - Proof of Concept" Height="450" Width="800">

    <!-- Verknüpfung des ViewModels als DataContext -->
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Grid.Row="0">
            <Button Content="Load Addresses" Command="{Binding LoadAddressesCommand}" Width="120" Height="30" Margin="0,0,10,0"/>
            <Button Content="Add Test Address" Command="{Binding AddTestAddressCommand}" Width="120" Height="30"/>
        </StackPanel>

        <!-- Das DataGrid zeigt automatisch die Properties unserer Address-Klasse als Spalten an -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Addresses}" AutoGenerateColumns="True" IsReadOnly="True"/>
    </Grid>
</Window>
