<Window x:Class="DeviceServiceManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:DeviceServiceManager.ViewModels"
        xmlns:views="clr-namespace:DeviceServiceManager.Views"
        mc:Ignorable="d"
        Title="Device Service Manager" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <!-- Zuweisung ViewModel -> View -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:CustomerViewModel}">
            <views:CustomerView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:ContractListViewModel}">
            <views:ContractView />
            <!-- Hier stand vorher ContractListView, prüfe ob der Name so bei dir stimmt! -->
        </DataTemplate>
    </Window.Resources>

    <!-- HIER HAT DAS HAUPT-GRID GEFEHLT -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <!-- 240 Pixel für die Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Der gesamte restliche Platz für den Inhalt -->
        </Grid.ColumnDefinitions>

        <!-- 1. SPALTE: Left Sidebar (Menu) -->
        <Border Grid.Column="0" Background="#01355E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Corporate Identity / Logo Area -->
                <StackPanel Grid.Row="0" Margin="0,20,0,30">
                    <TextBlock Text="Weilandt Elektronik GmbH" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Service Manager" Foreground="#95A5A6" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Buttons with Icons -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="NAVIGATION" Foreground="White" FontSize="11" FontWeight="Bold" Margin="20,25,0,10"/>

                    <!-- Dashboard Button -->
                    <Button Command="{Binding NavigateDashboardCommand}" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="20,12" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <!-- Wichtig: Width, Height und Margin hinzugefügt! -->
                            <Image Source="/Assets/dashboard_icon.png" Width="18" Height="18" Margin="0,0,15,0" Stretch="Uniform"/>
                            <TextBlock Text="Dashboard" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Customers Button -->
                    <Button Command="{Binding NavigateCustomersCommand}" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="20,12" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/person_icon.png" Width="18" Height="18" Margin="0,0,15,0" Stretch="Uniform"/>
                            <TextBlock Text="Kunden" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Contracts Button -->
                    <Button Command="{Binding NavigateContractsCommand}" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="20,12" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/docs_icon.png" Width="18" Height="18" Margin="0,0,15,0" Stretch="Uniform"/>
                            <TextBlock Text="Wartungsverträge" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F5F7FA">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>

    </Grid>
</Window>